      },
      {
        "gujarati": "દરિયો કોણે બનાવ્યો?",
        "espanol": "¿Quién hizo el mar?",
        "tipo": "clipIndividual",
        "audioClip": "https://rubenbhai.github.io/GujaratiResources/audios/Modulo_1-1_Audio_002.mp3"
      },
      {
        "gujarati": "આપણને બધાને કોણે બનાવ્યા?",
        "espanol": "¿Quién nos hizo a todos?",
        "tipo": "clipIndividual",
        "audioClip": "https://rubenbhai.github.io/GujaratiResources/audios/Modulo_1-1_Audio_003.mp3"
      },
      {
        "gujarati": "રંગબેરંગી પતંગિયું કોણે બનાવ્યું?",
        "espanol": "¿Quién hizo la mariposa colorida?",
        "tipo": "clipIndividual",
        "audioClip": "https://rubenbhai.github.io/GujaratiResources/audios/Modulo_1-1_Audio_004.mp3"
      },
      {
        "gujarati": "યહોવા ઈશ્વરે બધું જ બનાવ્યું.",
        "espanol": "Jehová Dios hizo todo.",
        "tipo": "clipIndividual",
        "audioClip": "https://rubenbhai.github.io/GujaratiResources/audios/Modulo_1-1_Audio_005.mp3"
      }
    ]
  },
