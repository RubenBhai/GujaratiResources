  "1-3": {
    "titulo": "Lección 1.3 — La carta de Dipu",
    "fuente": "Libro 1, પાઠ ૩",
    "frases": [
      {
        "gujarati": "દીપુને પડી ખબર, દોસ્ત તેનો થયો બીમાર.",
        "espanol": "Dipu se enteró de que su amigo se enfermó.",
        "tipo": "clipIndividual",
        "audioClip": "https://rubenbhai.github.io/GujaratiResources/audios/Modulo_1-3_Audio_001.mp3"
      },
      {
        "gujarati": "લખીશ તેને ચિઠ્ઠી, લાગશે તેને મીઠ્ઠી.",
        "espanol": "Le escribiré una carta, la encontrará dulce.",
        "tipo": "clipIndividual",
        "audioClip": "https://rubenbhai.github.io/GujaratiResources/audios/Modulo_1-3_Audio_002.mp3"
      },
      {
        "gujarati": "પછી જઈને આપીશ, એ વાંચીને ખુશ થશે તે!",
        "espanol": "Luego iré y se la daré; al leerla, estará feliz.",
        "tipo": "clipIndividual",
        "audioClip": "https://rubenbhai.github.io/GujaratiResources/audios/Modulo_1-3_Audio_003.mp3"
      },
      {
        "gujarati": "ભલું કરશો તો, ખુશ થશો!",
        "espanol": "¡Si haces el bien, serás feliz!",
        "tipo": "clipIndividual",
        "audioClip": "https://rubenbhai.github.io/GujaratiResources/audios/Modulo_1-3_Audio_004.mp3"
      }
    ]
  }
}
